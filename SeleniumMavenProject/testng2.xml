<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserSuite"
       parallel="tests"
       thread-count="3">

    <!-- Chrome Test -->
    <test name="ChromeTest">

        <parameter name="browser"
                   value="chrome"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserTest"/>

        </classes>

    </test>

    <!-- Edge Test -->
    <test name="EdgeTest">

        <parameter name="browser"
                   value="edge"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserTest"/>

        </classes>

    </test>

    <!-- Firefox Test -->
    <test name="FirefoxTest">

        <parameter name="browser"
                   value="firefox"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserTest"/>

        </classes>

    </test>

</suite>