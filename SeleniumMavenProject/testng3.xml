<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrossBrowserSuite"
       parallel="tests"
       thread-count="3">

    <!-- Chrome Test -->

    <test name="ChromeTest">

        <parameter name="browser"
                   value="chrome"/>

        <parameter name="username"
                   value="standard_user"/>

        <parameter name="password"
                   value="secret_sauce"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserLoginTest"/>

        </classes>

    </test>

    <!-- Edge Test -->

    <test name="EdgeTest">

        <parameter name="browser"
                   value="edge"/>

        <parameter name="username"
                   value="standard_user"/>

        <parameter name="password"
                   value="secret_sauce"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserLoginTest"/>

        </classes>

    </test>

    <!-- Firefox Test -->

    <test name="FirefoxTest">

        <parameter name="browser"
                   value="firefox"/>

        <parameter name="username"
                   value="standard_user"/>

        <parameter name="password"
                   value="secret_sauce"/>

        <classes>

            <class name="Day27_testcase.CrossBrowserLoginTest"/>

        </classes>

    </test>

</suite>